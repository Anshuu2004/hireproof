# HireProof — environment template. Copy to .env.local and fill in.
# No real secret is committed; .env.local is git-ignored.

# ── Supabase (Postgres + pgvector, project in ap-south-1 / Mumbai) ─────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only; never exposed to the client

# ── Credential issuer (Ed25519) ───────────────────────────────────────────────
# Generate a fresh keypair (hex) with:
#   node -e "import('jose').then(async j=>{const{publicKey,privateKey}=await j.generateKeyPair('EdDSA',{extractable:true});const pk=await j.exportJWK(privateKey),pub=await j.exportJWK(publicKey);const h=b=>Buffer.from(b,'base64url').toString('hex');console.log('ISSUER_PRIVATE_KEY_HEX='+h(pk.d));console.log('ISSUER_PUBLIC_KEY_HEX='+h(pub.x));})"
ISSUER_PRIVATE_KEY_HEX=   # 32-byte Ed25519 private scalar, hex. The crown jewel — see SECURITY.md T1.
ISSUER_PUBLIC_KEY_HEX=    # 32-byte Ed25519 public key, hex. Published at /.well-known/did.json.

# Optional. On Vercel the DID + site URL derive from the production domain.
# ISSUER_DID=did:web:hireproof.app
# NEXT_PUBLIC_SITE_URL=https://hireproof.app

# Optional key-management knobs (defaults are fine for the prototype):
# ISSUER_KEY_ID=key-1                 # active key id → JWS kid + did:web verificationMethod id
# ISSUER_RETIRED_PUBLIC_KEYS=         # comma-separated hex public keys still trusted during a rotation window
# ISSUER_SIGNER=env                   # "env" (key in env var, current) or "kms" (HSM-backed, roadmap stub)

# ── Vercel AI Gateway (Claude / Gemini for the planted-error task + grader) ────
# On Vercel an OIDC token is injected automatically; only needed for local dev.
# AI_GATEWAY_API_KEY=

# ── DigiLocker demo sandbox (defaults let the demo run with zero config) ───────
# DIGILOCKER_ORG_ID=HP-DEMO-ORG
# DIGILOCKER_DEMO_SECRET=hireproof-digilocker-demo-shared-secret
